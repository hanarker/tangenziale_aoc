# Obbligatoria: chiave API OpenAI
OPENAI_API_KEY=sk-proj-...

# Intervallo di scraping automatico (minuti, default: 60).
# L'LLM viene richiamato solo se il testo estratto è cambiato dall'ultimo scraping.
UPDATE_INTERVAL_MINUTES=60

# Opzionali avanzate
TARGET_URL=https://www.tangenzialedinapoli.it
# CRON_INTERVAL=*/60 * * * *   # override completo (ha la precedenza su UPDATE_INTERVAL_MINUTES)

# Obbligatorie: storage stato su Upstash Redis (vedi `vercel env pull .env.local`
# dopo aver collegato l'integrazione Marketplace "Upstash for Redis" al progetto)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Obbligatoria solo per app/api/cron/update (Vercel Cron Job): deve combaciare
# con l'header Authorization: Bearer <CRON_SECRET> inviato da Vercel
CRON_SECRET=
