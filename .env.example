# Obbligatoria: chiave API OpenAI
OPENAI_API_KEY=sk-proj-...

# Intervallo di scraping automatico (minuti, default: 60).
# L'LLM viene richiamato solo se il testo estratto è cambiato dall'ultimo scraping.
UPDATE_INTERVAL_MINUTES=60

# Opzionali avanzate
TARGET_URL=https://www.tangenzialedinapoli.it
# CRON_INTERVAL=*/60 * * * *   # override completo (ha la precedenza su UPDATE_INTERVAL_MINUTES)
